# Copy this file to backend/.env and fill in real values as available.
# NEVER commit real secrets. NEVER expose these values via any API endpoint.

# Path to the SQLite DB file. Defaults to backend/data/foreclosure.db if
# left blank. In production (Railway), point this at a mounted Volume,
# e.g. DB_PATH=/data/foreclosure.db.
DB_PATH=

TITLE_SEARCH_API_KEY=
TITLE_SEARCH_PROVIDER=
CRIME_DATA_API_KEY=
FEMA_API_BASE_URL=https://www.fema.gov/api/open/v2
SCRAPE_RATE_LIMIT_SECONDS=5
SCRAPE_SCHEDULE_HOUR=3

# PORT is auto-injected by Railway at runtime - do not set it manually here.
