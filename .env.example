# .env.example - Florida Foreclosure Auction Analysis & Ranking Tool
# Copy this file to .env and fill in real values. These are SERVER-SIDE ONLY
# secrets/config. They are read by backend/config.py via python-dotenv and are
# NEVER exposed to the frontend/browser.

# --- Database location ---
# Path to the SQLite DB file. Defaults to backend/data/foreclosure.db if
# left blank (fine for local dev). In production (e.g. Railway), set this
# to a path inside a mounted persistent Volume so data survives restarts/
# redeploys, e.g. DB_PATH=/data/foreclosure.db with a Volume mounted at /data.
DB_PATH=

# --- Title Search Provider (optional, disabled by default) ---
# If left blank, POST /api/title-search/{property_id} returns a
# "not_configured" stub response and NO external paid service is ever called.
# Suggested providers: DataTree/First American, ATTOM Data, or a local
# county recorder API.
TITLE_SEARCH_API_KEY=
TITLE_SEARCH_PROVIDER=

# --- FBI Crime Data API (crime_rate scoring component) ---
# https://api.usa.gov/crime/fbi/cde/ - requires a free api.data.gov key.
# If left blank, crime_rate scoring is marked "unavailable" (not fabricated).
CRIME_DATA_API_KEY=

# --- FEMA OpenFEMA / NFHL (flood_zone lookups) ---
# Public API, no key required. Base URL can be overridden below.
FEMA_API_BASE_URL=https://www.fema.gov/api/open/v2

# --- PORT ---
# Do NOT set this manually in production. Railway (and most PaaS hosts)
# auto-injects PORT at runtime, and the Dockerfile's CMD reads it via
# ${PORT:-8000}. Only relevant locally if you want uvicorn on a non-8000
# port, e.g. `PORT=9000 sh -c 'uvicorn main:app --port $PORT'`.
